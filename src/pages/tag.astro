---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Fragment slot="head">
    <title th:text="|${tag.spec.displayName} - ${site.title}|"></title>
  </Fragment>

  <div class="border-b border-[var(--rule)] pb-6">
    <h1 th:text="${tag.spec.displayName}"></h1>
    <p
      class="mb-[0.6rem] flex flex-wrap items-center gap-[0.6rem] text-[0.78rem] uppercase tracking-[0.1em] text-[var(--ink-3)]"
    >
      <span th:text="|${posts.total} 篇文章|"></span>
    </p>
  </div>

  <ul class="m-0 list-none p-0" role="list">
    <li th:each="post : ${posts.items}" class="border-t border-[var(--rule)] first:border-t-0">
      <a
        class="group grid gap-5 py-8 text-inherit no-underline md:grid-cols-[minmax(0,1fr)_200px] md:items-start md:gap-8"
        th:href="@{${post.status.permalink}}"
      >
        <div class="flex flex-col gap-[0.55rem] self-center">
          <p
            class="m-0 text-[0.8rem] uppercase tracking-[0.1em] text-[var(--ink-3)]"
            th:text="${#dates.format(post.spec.publishTime, 'yyyy-MM-dd')}"
          >
          </p>
          <h2
            class="m-0 text-[1.35rem] leading-[1.3] text-[var(--ink)] transition-colors duration-150 ease-in-out group-hover:text-[var(--accent)]"
            th:text="${post.spec.title}"
          ></h2>
          <p
            class="m-0 text-[0.96rem] leading-[1.6] text-[var(--ink-2)]"
            th:text="${post.status.excerpt}"
          ></p>
        </div>
        <img
          th:unless="${#strings.isEmpty(post.spec.cover)}"
          class="block aspect-[4/3] w-full rounded-[10px] object-cover transition-opacity duration-200 ease-in-out group-hover:opacity-90"
          th:src="${post.spec.cover}"
        />
      </a>
    </li>
  </ul>

  <div
    th:if="${posts.total == 0}"
    class="rounded-[12px] border border-dashed border-[var(--rule)] bg-[color-mix(in_srgb,var(--bg)_88%,var(--bg-raised)_12%)] px-5 py-6 text-[0.95rem] text-[var(--ink-2)]"
  >
    暂无文章。
  </div>

  <nav
    th:if="${posts.totalPages gt 1}"
    class="mt-2 flex flex-wrap items-center justify-between gap-4 border-t border-[var(--rule)] pt-6"
    aria-label="Pagination"
  >
    <a
      th:if="${posts.hasPrevious()}"
      th:href="@{${posts.prevUrl}}"
      class="inline-flex items-center gap-2 rounded-[8px] px-3 py-2 text-[0.92rem] font-medium text-[var(--ink-2)] no-underline transition-colors duration-150 ease-in-out hover:bg-[var(--bg-raised)] hover:text-[var(--ink)]"
      >&larr; 较新</a
    >
    <span
      class="text-[0.82rem] uppercase tracking-[0.12em] text-[var(--ink-3)]"
      th:text="|${posts.page} / ${posts.totalPages}|"></span>
    <a
      th:if="${posts.hasNext()}"
      th:href="@{${posts.nextUrl}}"
      class="inline-flex items-center gap-2 rounded-[8px] px-3 py-2 text-[0.92rem] font-medium text-[var(--ink-2)] no-underline transition-colors duration-150 ease-in-out hover:bg-[var(--bg-raised)] hover:text-[var(--ink)]"
      >较旧 &rarr;</a
    >
  </nav>
</Layout>
