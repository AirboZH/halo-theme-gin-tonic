---
// TODO: Only execute when compiling Astro templates, so it will not be dynamically updated
const today = new Date();
---

<footer class="border-t border-[var(--rule)] bg-[var(--bg)]">
  <div
    class="mx-auto flex w-[820px] max-w-[calc(100%-2.5rem)] items-center justify-between gap-4 py-6 pb-10 text-[0.88rem] text-[var(--ink-3)]"
  >
    <span>
      &copy; {today.getFullYear()}
      <th:block th:text="${site.title}"></th:block>.
    </span>
  </div>
</footer>
